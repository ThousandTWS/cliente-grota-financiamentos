{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "pom.xml", "src/**"],
      "outputs": [".next/**", "!.next/cache/**", "target/**", "dist/**"]
    },
    "run-java": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["grota-website#build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
    
  },
  "globalEnv": [
    "NEXT_PUBLIC_URL_API",
    "LOGISTA_SESSION_SECRET",
    "LOGISTA_API_BASE_URL",
    "ADMIN_SESSION_SECRET",
    "NEXT_PUBLIC_LOGISTA_PANEL_URL",
    "ADMIN_API_BASE_URL",
    "DEFAULT_API_BASE_URL",
    "ARCJET_KEY",
    "APIBRASIL_DEVICE_TOKEN_CPF",
    "APIBRASIL_TOKEN",
    "GEMINI_API_KEY"
  ]
}
