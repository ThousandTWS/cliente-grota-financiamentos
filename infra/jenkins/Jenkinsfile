pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '20'))
    timeout(time: 45, unit: 'MINUTES')
  }

  parameters {
    booleanParam(name: 'DEPLOY', defaultValue: false, description: 'Run deployment steps after a successful build')
    string(name: 'ENV_FILE_CREDENTIAL_ID', defaultValue: '', description: 'Jenkins file credential containing .env values for Next.js builds (optional)')
  }

  environment {
    NODE_ENV = 'production'
    CI = 'true'
    PNPM_STORE_PATH = "${WORKSPACE}/.pnpm-store"
    NODE_VERSION = 'v20.18.1'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Node and pnpm') {
      steps {
        script {
          def nodeVersion = env.NODE_VERSION ?: 'v20.18.1'
          def nodeDist = "node-${nodeVersion}-linux-x64"
          def nodeArchive = "${nodeDist}.tar.gz"
          def toolingDir = "${env.WORKSPACE}/.tooling"
          def nodeBin = "${toolingDir}/${nodeDist}/bin"

          sh """
            set -euo pipefail

            NODE_VERSION="${nodeVersion}"
            NODE_DIST="${nodeDist}"
            NODE_ARCHIVE="${nodeArchive}"
            TOOLING_DIR="${toolingDir}"
            NODE_BIN="${nodeBin}"

            mkdir -p "\$TOOLING_DIR"

            if ! command -v node >/dev/null 2>&1; then
              echo "Node.js not found; installing ${nodeVersion} into ${toolingDir}"
              cd "\$TOOLING_DIR"
              if [ ! -d "\$NODE_DIST" ]; then
                if command -v curl >/dev/null 2>&1; then
                  curl -fsSLO "https://nodejs.org/dist/${nodeVersion}/${nodeArchive}"
                elif command -v wget >/dev/null 2>&1; then
                  wget -q "https://nodejs.org/dist/${nodeVersion}/${nodeArchive}"
                else
                  echo "curl/wget not available to download Node.js." >&2
                  exit 1
                fi
                tar -xzf "\$NODE_ARCHIVE"
              fi
            fi

            export PATH="${nodeBin}:\$PATH"

            if command -v corepack >/dev/null 2>&1; then
              corepack enable
              corepack prepare pnpm@9.0.0 --activate
            else
              echo "corepack not found; installing pnpm via npm -g"
              if command -v npm >/dev/null 2>&1; then
                npm install -g pnpm@9.0.0
              else
                echo "npm not found even after Node install; check PATH." >&2
                exit 1
              fi
            fi

            pnpm config set store-dir "${env.PNPM_STORE_PATH}"
            node -v
            npm -v
            pnpm -v
          """

          // Ensure subsequent stages use the local Node/pnpm
          env.PATH = "${nodeBin}:${env.PATH}"
        }
      }
    }

    stage('Install JS dependencies') {
      steps {
        sh 'pnpm install --frozen-lockfile --prefer-offline --store-dir "$PNPM_STORE_PATH"'
      }
    }

    stage('Apply frontend env (optional)') {
      when {
        expression { params.ENV_FILE_CREDENTIAL_ID?.trim() }
      }
      steps {
        withCredentials([file(credentialsId: params.ENV_FILE_CREDENTIAL_ID, variable: 'ENV_FILE')]) {
          sh '''
            set -e
            cp "$ENV_FILE" .env.ci || true
            cp "$ENV_FILE" .env.production.local || true
          '''
        }
      }
    }

    stage('Quality gates') {
      parallel {
        stage('Lint') {
          steps {
            sh 'pnpm lint'
          }
        }
        stage('Type check') {
          steps {
            sh 'pnpm check-types'
          }
        }
      }
    }

    stage('Build frontends') {
      steps {
        sh 'pnpm build'
      }
    }

    stage('Build Spring API') {
      steps {
        dir('apps/api-service') {
          sh '''
            set -e
            chmod +x mvnw
            ./mvnw -B clean verify
          '''
        }
      }
    }

    stage('Archive artifacts') {
      steps {
        archiveArtifacts artifacts: 'apps/api-service/target/*.jar', fingerprint: true, allowEmptyArchive: true
        archiveArtifacts artifacts: 'apps/**/.next/**', allowEmptyArchive: true
        junit allowEmptyResults: true, testResults: 'apps/api-service/target/surefire-reports/*.xml'
      }
    }

    stage('Deploy') {
      when {
        allOf {
          branch 'main'
          expression { params.DEPLOY }
        }
      }
      steps {
        sh '''
          echo "Deploy placeholder - add helm/kubectl/ssh/terraform steps to promote artifacts."
        '''
      }
    }
  }

  post {
    success {
      echo 'CI pipeline completed successfully.'
    }
    failure {
      echo 'CI pipeline failed.'
    }
  }
}
