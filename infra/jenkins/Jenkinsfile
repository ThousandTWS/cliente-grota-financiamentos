pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '20'))
    timeout(time: 45, unit: 'MINUTES')
    timestamps()
  }

  parameters {
    booleanParam(name: 'DEPLOY', defaultValue: false, description: 'Gate: allow deploy on main (Railway/Vercel auto deploy from GitHub)')
    string(name: 'ENV_FILE_CREDENTIAL_ID', defaultValue: '', description: 'Optional .env file credential for Next.js builds')
  }

  environment {
    CI = 'true'
    PNPM_STORE_PATH = "${WORKSPACE}/.pnpm-store"
    NODE_VERSION = '20.18.1' // sem "v"
    TOOLING_DIR = "${WORKSPACE}/.tooling"
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Setup Node + pnpm') {
      steps {
        script {
          def nodeVersion = (env.NODE_VERSION ?: '20.18.1').trim()
          def nodeDist    = "node-v${nodeVersion}-linux-x64"
          def nodeArchive = "${nodeDist}.tar.gz"
          def toolingDir  = env.TOOLING_DIR
          def nodeRoot    = "${toolingDir}/${nodeDist}"
          def nodeBin     = "${nodeRoot}/bin"

          sh """
            set -eu
            mkdir -p "${toolingDir}"

            if [ ! -x "${nodeBin}/node" ]; then
              echo "[setup] Installing Node v${nodeVersion}"
              cd "${toolingDir}"

              if [ ! -f "${nodeArchive}" ]; then
                if command -v curl >/dev/null 2>&1; then
                  curl -fsSLO "https://nodejs.org/dist/v${nodeVersion}/${nodeArchive}"
                else
                  wget -q "https://nodejs.org/dist/v${nodeVersion}/${nodeArchive}"
                fi
              fi

              rm -rf "${nodeDist}"
              tar -xzf "${nodeArchive}"
            fi

            export PATH="${nodeBin}:\$PATH"

            if command -v corepack >/dev/null 2>&1; then
              corepack enable >/dev/null 2>&1 || true
              corepack prepare pnpm@9.0.0 --activate
            else
              npm install -g pnpm@9.0.0
            fi

            pnpm config set store-dir "${PNPM_STORE_PATH}"
            node -v && pnpm -v
          """

          env.PATH = "${nodeBin}:${env.PATH}"
        }
      }
    }

    stage('Install JS deps') {
      steps {
        sh '''
          set -eu
          pnpm install --frozen-lockfile --prefer-offline --store-dir "$PNPM_STORE_PATH"
        '''
      }
    }

    stage('Apply frontend env (optional)') {
      when { expression { (params.ENV_FILE_CREDENTIAL_ID ?: '').trim() } }
      steps {
        withCredentials([file(credentialsId: params.ENV_FILE_CREDENTIAL_ID, variable: 'ENV_FILE')]) {
          sh '''
            set -eu
            cp "$ENV_FILE" .env.production.local
            cp "$ENV_FILE" .env.ci || true
          '''
        }
      }
    }

    stage('Quality gates') {
      parallel {
        stage('Lint') { steps { sh 'pnpm lint' } }
        stage('Type check') { steps { sh 'pnpm check-types' } }
      }
    }

    stage('Build front (for validation)') {
      steps { sh 'pnpm build' }
    }

    stage('Build + Test api-service') {
      steps {
        dir('apps/api-service') {
          sh '''
            set -eu
            chmod +x mvnw
            ./mvnw -B clean verify
          '''
        }
      }
    }

    stage('Archive') {
      steps {
        archiveArtifacts artifacts: 'apps/api-service/target/*.jar', fingerprint: true, allowEmptyArchive: true
        junit allowEmptyResults: true, testResults: 'apps/api-service/target/surefire-reports/*.xml'
      }
    }

    stage('Deploy gate (Railway/Vercel)') {
      when {
        allOf {
          branch 'main'
          expression { params.DEPLOY }
        }
      }
      steps {
        echo 'Deploy gate OK: push on main will auto-deploy on Railway (api-service) and Vercel (front).'
      }
    }
  }

  post {
    success { echo 'CI OK.' }
    failure { echo 'CI FAIL.' }
    always { echo "Branch: ${env.BRANCH_NAME} | DEPLOY gate: ${params.DEPLOY}" }
  }
}
