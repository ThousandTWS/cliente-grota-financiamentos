{
  "name": "grota_financiamentos",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "run-java": "turbo run run-java",
    "realtime": "pnpm --filter @grota/realtime-server dev",
    "gen": "node generators/package/index.js",
    "graph": "turbo graph --html",
    "graph:pdf": "turbo graph --pdf"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.9.19",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "install": "^0.13.0",
    "smart-webcomponents-react": "^25.0.3"
  }
}
