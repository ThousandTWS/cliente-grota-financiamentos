<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="202603210005-1" author="codex">
        <addColumn tableName="dealer">
            <column name="full_name" type="varchar(150)"/>
            <column name="phone" type="varchar(30)"/>
            <column name="enterprise" type="varchar(150)"/>
            <column name="password_hash" type="varchar(100)"/>
            <column name="razao_social" type="varchar(200)"/>
            <column name="cnpj" type="varchar(20)"/>
            <column name="zip_code" type="varchar(20)"/>
            <column name="street" type="varchar(150)"/>
            <column name="number" type="varchar(20)"/>
            <column name="complement" type="varchar(100)"/>
            <column name="neighborhood" type="varchar(100)"/>
            <column name="city" type="varchar(100)"/>
            <column name="state" type="varchar(20)"/>
            <column name="observation" type="varchar(500)"/>
            <column name="reference_code" type="varchar(30)"/>
            <column name="logo_url" type="varchar(255)"/>
            <column name="status" type="varchar(30)" defaultValue="ATIVO"/>
            <column name="created_at" type="timestamp"/>
        </addColumn>

        <addUniqueConstraint tableName="dealer" columnNames="cnpj" constraintName="ux_dealer_cnpj"/>
        <addUniqueConstraint tableName="dealer" columnNames="phone" constraintName="ux_dealer_phone"/>
        <addUniqueConstraint tableName="dealer" columnNames="reference_code" constraintName="ux_dealer_reference_code"/>
    </changeSet>

    <changeSet id="202603210005-2" author="codex">
        <createTable tableName="dealer_partner">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="dealer_partner_pk"/>
            </column>
            <column name="dealer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="cpf" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="signatory" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="dealer_partner"
            baseColumnNames="dealer_id"
            referencedTableName="dealer"
            referencedColumnNames="id"
            onDelete="CASCADE"
            constraintName="fk_dealer_partner_dealer"/>
    </changeSet>
</databaseChangeLog>
