<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="202603210003-1" author="codex">
        <addColumn tableName="seller">
            <column name="street" type="varchar(255)"/>
            <column name="number" type="varchar(50)"/>
            <column name="complement" type="varchar(255)"/>
            <column name="neighborhood" type="varchar(255)"/>
            <column name="city" type="varchar(255)"/>
            <column name="state" type="varchar(100)"/>
            <column name="zip_code" type="varchar(30)"/>
            <column name="password_hash" type="varchar(100)"/>
        </addColumn>
        <addUniqueConstraint tableName="seller" columnNames="email" constraintName="ux_seller_email"/>
        <addUniqueConstraint tableName="seller" columnNames="cpf" constraintName="ux_seller_cpf"/>
        <addUniqueConstraint tableName="seller" columnNames="phone" constraintName="ux_seller_phone"/>
    </changeSet>
</databaseChangeLog>
